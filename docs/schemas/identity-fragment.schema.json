{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helixa.ai/multipass/identity-fragment.schema.json",
  "title": "Identity Fragment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fragment_id",
    "multipass_id",
    "fragment_type",
    "status",
    "assurance_level",
    "visibility",
    "transfer_policy",
    "source",
    "created_at",
    "updated_at"
  ],
  "allOf": [
    {
      "if": {
        "required": [
          "fragment_type"
        ],
        "properties": {
          "fragment_type": {
            "const": "tool_manifest"
          }
        }
      },
      "then": {
        "required": [
          "tool_manifest_ref"
        ],
        "properties": {
          "tool_manifest_ref": {
            "type": "object"
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "fragment_id": {
      "type": "string",
      "minLength": 1
    },
    "multipass_id": {
      "type": "string",
      "minLength": 1
    },
    "fragment_type": {
      "type": "string",
      "enum": [
        "wallet",
        "social",
        "domain",
        "project",
        "collection",
        "endpoint",
        "attestation",
        "receipt",
        "standard_ref",
        "risk_summary",
        "tool_manifest",
        "work_record",
        "custody_record",
        "verification_result"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "verified",
        "stale",
        "revoked",
        "disputed",
        "historical"
      ]
    },
    "assurance_level": {
      "type": "string",
      "enum": [
        "unverified",
        "self_attested",
        "platform_verified",
        "cryptographic",
        "issuer_attested",
        "onchain_verified"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "gated",
        "private",
        "hidden"
      ]
    },
    "transfer_policy": {
      "type": "string",
      "enum": [
        "reverify_on_transfer",
        "pause_on_transfer",
        "historical_on_transfer",
        "never_transfer"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_id",
        "issuer",
        "observed_at"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "owner_submission",
            "platform_check",
            "issuer_attestation",
            "contract_read",
            "registry_import",
            "payment_receipt"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "issuer": {
          "type": [
            "string",
            "null"
          ]
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "reference_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "redaction_note": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "public_value": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    },
    "proof_reference": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "content_hash": {
      "type": [
        "string",
        "null"
      ],
      "description": "Hash or commitment for content that should not be returned raw."
    },
    "issuer": {
      "type": [
        "string",
        "null"
      ],
      "description": "Issuer or attester associated with the fragment when applicable."
    },
    "verifier": {
      "type": [
        "string",
        "null"
      ],
      "description": "Verifier associated with the fragment when applicable."
    },
    "verified_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "revoked_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "endpoint_ref": {
      "type": [
        "object",
        "null"
      ],
      "description": "Endpoint-specific fields for endpoint fragments.",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "url",
        "protocol"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "web",
            "api",
            "mcp",
            "a2a",
            "x402",
            "x401"
          ]
        },
        "manifest_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    },
    "tool_manifest_ref": {
      "type": [
        "object",
        "null"
      ],
      "description": "Tool-specific fields for tool manifest fragments.",
      "additionalProperties": false,
      "required": [
        "tool_id",
        "registry",
        "name",
        "description",
        "endpoint_url",
        "pricing",
        "access",
        "schemas",
        "verifiability"
      ],
      "properties": {
        "tool_id": {
          "type": "string",
          "minLength": 1
        },
        "registry": {
          "type": "string",
          "enum": [
            "bankr_x402_cloud",
            "opensea_agent_tool_registry",
            "helixa_api",
            "owner_submitted",
            "unknown"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "endpoint_url": {
          "type": "string",
          "format": "uri"
        },
        "manifest_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "manifest_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "creator_address": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^0x[0-9a-f]{40}$"
        },
        "pricing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model",
            "amount",
            "asset",
            "chain_id"
          ],
          "properties": {
            "model": {
              "type": "string",
              "enum": [
                "free",
                "fixed",
                "metered",
                "unknown"
              ]
            },
            "amount": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            },
            "asset": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "chain_id": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            }
          }
        },
        "access": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "requires_owner_approval"
          ],
          "properties": {
            "summary": {
              "type": [
                "string",
                "null"
              ]
            },
            "requires_owner_approval": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "schemas": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_summary",
            "output_summary"
          ],
          "properties": {
            "input_summary": {
              "type": [
                "string",
                "null"
              ]
            },
            "output_summary": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "verifiability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tier",
            "summary"
          ],
          "properties": {
            "tier": {
              "type": [
                "string",
                "null"
              ]
            },
            "summary": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "last_checked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "marketplace_ref": {
      "type": [
        "object",
        "null"
      ],
      "description": "Display-only public marketplace connection metadata for manager-supplied attestation fragments.",
      "additionalProperties": false,
      "required": [
        "marketplace",
        "profile_url",
        "title",
        "summary",
        "status"
      ],
      "properties": {
        "marketplace": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "profile_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 500
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "listing_id": {
          "type": "string",
          "maxLength": 120
        },
        "status": {
          "type": "string",
          "enum": [
            "manager_supplied",
            "public_import",
            "pending",
            "stale",
            "disputed"
          ]
        },
        "source_checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "services": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "maxLength": 120
              },
              "price": {
                "type": "string",
                "maxLength": 80
              },
              "payment_mode": {
                "type": "string",
                "maxLength": 80
              },
              "endpoint_url": {
                "type": "string",
                "format": "uri",
                "maxLength": 500
              }
            }
          }
        },
        "payment_rails": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "asset": {
                "type": "string",
                "maxLength": 80
              },
              "mode": {
                "type": "string",
                "maxLength": 80
              },
              "chain": {
                "type": "string",
                "maxLength": 80
              }
            }
          }
        },
        "reputation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "string",
              "maxLength": 80
            },
            "positive_rate": {
              "type": "string",
              "maxLength": 80
            },
            "sold_count": {
              "type": "string",
              "maxLength": 80
            },
            "review_count": {
              "type": "string",
              "maxLength": 80
            }
          }
        },
        "facts": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "maxLength": 80
              },
              "value": {
                "type": "string",
                "maxLength": 160
              }
            }
          }
        }
      }
    },
    "custody_ref": {
      "type": [
        "object",
        "null"
      ],
      "description": "Custody-specific fields for custody record fragments.",
      "additionalProperties": false,
      "required": [
        "custody_epoch_id",
        "owner_controller_id",
        "status"
      ],
      "properties": {
        "custody_epoch_id": {
          "type": "string",
          "minLength": 1
        },
        "owner_controller_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "active",
            "historical",
            "transferred"
          ]
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "ended_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "verification_ref": {
      "type": [
        "object",
        "null"
      ],
      "description": "Verification-specific fields for verification result fragments.",
      "additionalProperties": false,
      "required": [
        "verification_type",
        "result",
        "issuer"
      ],
      "properties": {
        "verification_type": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "inconclusive",
            "expired"
          ]
        },
        "issuer": {
          "type": [
            "string",
            "null"
          ]
        },
        "risk_level": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            null
          ]
        },
        "score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "x401_proof_ref": {
      "type": [
        "object",
        "null"
      ],
      "description": "x401-specific public proof metadata. This never includes raw private credential material.",
      "additionalProperties": false,
      "required": [
        "protocol",
        "issuer_id",
        "requirement_id",
        "credential_format",
        "claim_types",
        "result",
        "private_credential_state"
      ],
      "properties": {
        "protocol": {
          "type": "string",
          "enum": [
            "x401"
          ]
        },
        "issuer_id": {
          "type": "string",
          "minLength": 1
        },
        "issuer_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 120
        },
        "requirement_id": {
          "type": "string",
          "minLength": 1
        },
        "credential_format": {
          "type": "string",
          "enum": [
            "openid4vp",
            "w3c_vc",
            "proof_satisfaction_token",
            "unknown"
          ]
        },
        "claim_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "result": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "inconclusive",
            "expired"
          ]
        },
        "header_names": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "request",
            "response",
            "result"
          ],
          "properties": {
            "request": {
              "type": "string",
              "enum": [
                "PROOF-REQUEST"
              ]
            },
            "response": {
              "type": "string",
              "enum": [
                "PROOF-RESPONSE"
              ]
            },
            "result": {
              "type": "string",
              "enum": [
                "PROOF-RESULT"
              ]
            }
          }
        },
        "required_before_payment": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "private_credential_state": {
          "type": "string",
          "enum": [
            "not_exposed",
            "redacted",
            "unavailable"
          ]
        }
      }
    }
  }
}
